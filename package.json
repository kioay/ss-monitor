{
  "name": "ss-sentiment-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc --noEmit",
    "test:search": "tsx scripts/test-search.ts",
    "test:topic-bars": "tsx scripts/test-topic-bars.ts",
    "test:monitor-history": "tsx scripts/test-monitor-history.ts",
    "test:douyin-game-routing": "tsx scripts/test-douyin-game-routing.ts",
    "test:risk-alerts": "tsx scripts/test-risk-alerts.ts",
    "test:dingtalk-daily-markdown": "tsx scripts/test-dingtalk-daily-markdown.ts",
    "test:semantic-guard": "tsx scripts/test-bettafish-semantic-guard.ts",
    "start": "tsx server/index.ts",
    "sync:confluence": "tsx scripts/sync-current-version-focus.ts",
    "sync:bettafish-semantic": "tsx scripts/sync-bettafish-semantic.ts",
    "sync:bettafish-full": "tsx scripts/sync-bettafish-full.ts",
    "verify:bettafish-production": "tsx scripts/verify-bettafish-production.ts",
    "apply:bettafish-credentials": "tsx scripts/apply-bettafish-credentials.ts",
    "douyin:server-login": "tsx scripts/douyin-server-login.ts",
    "douyin:prepare-local-export": "tsx scripts/prepare-local-douyin-export.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "cheerio": "^1.1.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.556.0",
    "mysql2": "^3.22.4",
    "pg": "^8.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "vite": "^7.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "ssh2": "^1.17.0",
    "typescript": "^5.9.3"
  }
}
