# 后端端口
PORT=8787
HOST=127.0.0.1

# 更新频率：日间每 1 小时，夜间每 4 小时。刷新按钮仍会强制重新采集。
DAY_UPDATE_INTERVAL_MINUTES=60
NIGHT_UPDATE_INTERVAL_MINUTES=240
NIGHT_START_HOUR=0
NIGHT_END_HOUR=8

# 默认只展示最近多少小时的数据，前端可调整。后端仍会强制按窗口过滤旧消息。
DEFAULT_WINDOW_HOURS=72

# B 站和贴吧遇到风控时，把浏览器里对应站点的 Cookie 放到这里。
# 不配置也能尝试公开接口；配置后视频详情、评论、弹幕和贴吧页面成功率更高。
BILIBILI_COOKIE=
BAIDU_COOKIE=

# Authorized Douyin exports. Put CSV/JSON files under this ignored data directory.
# These files are read locally and merged into the Douyin sentiment pipeline.
DOUYIN_IMPORT_DIR=data/douyin-imports
DOUYIN_AUTHORIZED_SOURCES_PATH=data/douyin-authorized-sources.json
MAX_DOUYIN_IMPORTED_ITEMS_PER_GAME=80

# Optional BettaFish / MindSpider integration.
# Keep the BettaFish repo and its credentials outside this project. Export authorized rows to JSON/CSV here.
BETTAFISH_IMPORT_DIR=data/bettafish-imports
MAX_BETTAFISH_IMPORTED_ITEMS_PER_GAME=80
# Optional running BettaFish Flask instance, used only for status checks such as /api/status.
BETTAFISH_BASE_URL=

# BettaFish test-lab actions. Keep disabled in production unless the endpoint is protected.
# When disabled, the frontend still shows all controls, but POST actions return a safe message.
BETTAFISH_LAB_ACTIONS_ENABLED=false
BETTAFISH_REPO_DIR=
BETTAFISH_PYTHON=python
# Optional overrides for local process control and deployment from the test lab.
BETTAFISH_START_COMMAND=
BETTAFISH_DEPLOY_COMMAND=
# Optional local model command. The command receives the text on stdin and in BETTAFISH_SENTIMENT_TEXT.
BETTAFISH_SENTIMENT_COMMAND=

# Optional authorized API source secrets. Keep real values out of Git.
DOUYIN_OPEN_PLATFORM_COMMENTS_URL=
DOUYIN_OPEN_PLATFORM_ACCESS_TOKEN=
JULIANG_SUANSHU_ENDPOINT=
JULIANG_SUANSHU_TOKEN=
DOUYIN_VENDOR_ENDPOINT=
DOUYIN_VENDOR_TOKEN=

# DingTalk robot notification. Keep real webhook/secret on the server only.
# State files deduplicate pushed items across restarts.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_STATE_PATH=/opt/ss-monitor/state/dingtalk-ss1-state.json
DINGTALK_SS2_WEBHOOK=
DINGTALK_SS2_SECRET=
DINGTALK_SS2_STATE_PATH=/opt/ss-monitor/state/dingtalk-ss2-state.json

# 抖音不使用官方接口：当前通过公开搜索结果发现公开视频/图文，并严格按时间窗口过滤。
# 不配置 Cookie；如果公开搜索被安全验证拦截，平台会在采集状态里标注受限。
