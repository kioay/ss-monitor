# 后端端口
PORT=8787
HOST=127.0.0.1

# 更新频率：日间每 1 小时，夜间每 4 小时。刷新按钮仍会强制重新采集。
DAY_UPDATE_INTERVAL_MINUTES=60
NIGHT_UPDATE_INTERVAL_MINUTES=240
NIGHT_START_HOUR=0
NIGHT_END_HOUR=8

# 默认只展示最近多少小时的数据，前端可调整。后端仍会强制按窗口过滤旧消息。
DEFAULT_WINDOW_HOURS=72
MONITOR_HISTORY_PATH=data/monitor-history.json
MONITOR_HISTORY_RETENTION_HOURS=720
MONITOR_HISTORY_MAX_ITEMS=5000

# Monitored projects. Leave empty to use the built-in SS1/SS2 defaults.
# For custom deployments, either set MONITOR_GAMES_JSON directly or point
# MONITOR_GAMES_PATH to a server-local JSON file such as data/monitor-games.json.
# Example:
# MONITOR_GAMES_JSON=[{"id":"out-of-control","name":"失控进化","shortName":"失控进化","bilibiliKeywords":["失控进化"],"douyinKeywords":["失控进化"],"tiebaBars":["失控进化"]}]
# tiebaBars accepts multiple bar names. UI supplemental entries also expand the
# temporary Tieba bar scope for the current refresh.
MONITOR_GAMES_JSON=
MONITOR_GAMES_PATH=

# B 站和贴吧遇到风控时，把浏览器里对应站点的 Cookie 放到这里。
# 不配置也能尝试公开接口；配置后视频详情、评论、弹幕和贴吧页面成功率更高。
BILIBILI_COOKIE=
BAIDU_COOKIE=
MAX_BILIBILI_SEARCH_PAGES=5
MAX_BILIBILI_VIDEOS_PER_GAME=120
MAX_TIEBA_LIST_PAGES=5
TIEBA_THREADS_PER_PAGE=30
MAX_TIEBA_THREADS_PER_BAR=150

# Current-version focus from Confluence.
# Internal production can reach Confluence directly; keep the real token only on the server.
CONFLUENCE_TOKEN=
CONFLUENCE_PAGE_ID=231710712
CURRENT_VERSION_FOCUS_CACHE_PATH=data/current-version-focus.json

# Authorized Douyin exports. Put CSV/JSON files under this ignored data directory.
# These files are read locally and merged into the Douyin sentiment pipeline.
DOUYIN_IMPORT_DIR=data/douyin-imports
DOUYIN_AUTHORIZED_SOURCES_PATH=data/douyin-authorized-sources.json
MAX_DOUYIN_ITEMS_PER_GAME=300
MAX_DOUYIN_IMPORTED_ITEMS_PER_GAME=300
# Public Sogou discovery is disabled by default so Douyin is handled by experimental/authorized sources.
DOUYIN_PUBLIC_SEARCH_ENABLED=false
DOUYIN_COOKIES_B64=
# noVNC/remote-desktop URL for manual server-side Douyin login.
# On production, prefer: sudo bash /opt/ss-monitor/current/scripts/setup-douyin-remote-login.sh
# The setup script fills the URL, service, ports, noVNC path, and local password.
# Set DOUYIN_REMOTE_LOGIN_HOST before running setup only when the noVNC URL must be pinned.
DOUYIN_REMOTE_LOGIN_URL=
DOUYIN_REMOTE_LOGIN_SERVICE=ss-monitor-douyin-remote-login.service
BETTAFISH_DOUYIN_REMOTE_NOVNC_PORT=6088
BETTAFISH_DOUYIN_REMOTE_VNC_PORT=5988
BETTAFISH_DOUYIN_REMOTE_PASSWORD=
BETTAFISH_DOUYIN_REMOTE_NOVNC_DIR=
BETTAFISH_DOUYIN_REMOTE_NOVNC_WEB=
BETTAFISH_DOUYIN_REMOTE_NOVNC_PROXY=
BETTAFISH_DOUYIN_REMOTE_XVNC=

# Production BettaFish Douyin scheduler. The timer fires hourly; the runner
# enforces these day/night intervals before invoking upstream MediaCrawler.
BETTAFISH_DOUYIN_DAY_INTERVAL_MINUTES=60
BETTAFISH_DOUYIN_NIGHT_INTERVAL_MINUTES=240
BETTAFISH_DOUYIN_NIGHT_START_HOUR=0
BETTAFISH_DOUYIN_NIGHT_END_HOUR=8
BETTAFISH_DOUYIN_LOGIN_TYPE=cookie
BETTAFISH_DOUYIN_HEADLESS=true
BETTAFISH_DOUYIN_GET_COMMENT=true
BETTAFISH_DOUYIN_GET_SUB_COMMENT=false
BETTAFISH_DOUYIN_SAVE_DATA_OPTION=db
BETTAFISH_DOUYIN_MAX_NOTES_COUNT=15
BETTAFISH_DOUYIN_MAX_COMMENTS_PER_ITEM=20
BETTAFISH_DOUYIN_SLEEP_SECONDS=2
# Optional comma-separated override. Default is SS1/SS2 project keywords.
BETTAFISH_DOUYIN_KEYWORDS=

# Optional BettaFish / MindSpider integration.
# Keep the BettaFish repo and its credentials outside this project. Export authorized rows to JSON/CSV here.
BETTAFISH_IMPORT_DIR=data/bettafish-imports
MAX_BETTAFISH_IMPORTED_ITEMS_PER_GAME=300
# Optional running BettaFish Flask instance. If omitted and a sibling BettaFish repo is found,
# the test lab defaults to http://127.0.0.1:5000.
BETTAFISH_BASE_URL=
# Public website and announcement surfaces are retired by default. The production
# verifier records them as skipped unless they are explicitly restored.
BETTAFISH_PUBLIC_RETIRED=true
BETTAFISH_ANNOUNCEMENT_RETIRED=true

# BettaFish test-lab research operations. Only fixed server-defined operations are exposed.
# Set false to make the public test bench read-only.
BETTAFISH_LAB_ACTIONS_ENABLED=true
BETTAFISH_REPO_DIR=
BETTAFISH_PYTHON=
# Optional overrides for local process control and deployment from the test lab.
# If a BettaFish repo is found, defaults are "python/python3 app.py" and
# "git pull --ff-only && git submodule update --init --recursive".
BETTAFISH_START_COMMAND=
BETTAFISH_DEPLOY_COMMAND=
# Optional local model command. The command receives the text on stdin and in BETTAFISH_SENTIMENT_TEXT.
BETTAFISH_SENTIMENT_COMMAND=

# Optional BettaFish semantic fusion for the main monitor. When enabled, the monitor
# batch-runs BettaFish local sentiment models and blends their high-confidence result
# with the existing SS1/SS2 domain analyzer. It never calls BettaFish LLMs by default.
BETTAFISH_SEMANTIC_ENABLED=true
BETTAFISH_SEMANTIC_COMMAND=
BETTAFISH_SEMANTIC_MODELS=bayes
BETTAFISH_SEMANTIC_MAX_ITEMS=80
BETTAFISH_SEMANTIC_TIMEOUT_MS=15000
BETTAFISH_SEMANTIC_MIN_CONFIDENCE=0.56
BETTAFISH_SEMANTIC_OVERRIDE_CONFIDENCE=0.72
BETTAFISH_SEMANTIC_RISK_CONFIDENCE=0.78
BETTAFISH_SEMANTIC_FAILURE_COOLDOWN_SECONDS=600

# Optional local-to-production sync for the lightweight BettaFish semantic model subset.
# Keep passwords in .env.local or process env, never in Git.
SYNC_BETTAFISH_LOCAL_REPO=
SYNC_BETTAFISH_REMOTE=
SYNC_BETTAFISH_SSH_PORT=22
SYNC_BETTAFISH_PASSWORD=
SYNC_BETTAFISH_ROOT_PASSWORD=
SYNC_BETTAFISH_REMOTE_ROOT=/opt/BettaFish
SYNC_BETTAFISH_MODELS=bayes
SYNC_BETTAFISH_INSTALL_DEPS=true
SYNC_BETTAFISH_PYTHON_PACKAGES=numpy<2 scipy<1.14 scikit-learn==0.24.2 jieba==0.42.1

# Full BettaFish production sync. This deploys the BettaFish app, Agent engines,
# ReportEngine, MindSpider, MediaCrawler code, templates, static assets, and model
# weights under /opt/BettaFish/current. By default production clones the exact
# upstream Git revision with submodules so .git/.github/tracked training datasets
# remain present for completeness checks. It still keeps .env, cookies, browser
# profiles, crawler output, downloaded media, reports, and caches out of archives
# and deployment state unless the explicit runtime-state include flag is set.
SYNC_BETTAFISH_FULL_LOCAL_REPO=
SYNC_BETTAFISH_FULL_REMOTE=
SYNC_BETTAFISH_FULL_SSH_PORT=22
SYNC_BETTAFISH_FULL_PASSWORD=
SYNC_BETTAFISH_FULL_REMOTE_ROOT=/opt/BettaFish
SYNC_BETTAFISH_FULL_CLONE_UPSTREAM=true
SYNC_BETTAFISH_FULL_UPSTREAM_URL=https://github.com/666ghj/BettaFish.git
SYNC_BETTAFISH_FULL_INSTALL_DEPS=true
SYNC_BETTAFISH_FULL_INSTALL_PLAYWRIGHT=true
SYNC_BETTAFISH_FULL_UPDATE_MONITOR_ENV=true
SYNC_BETTAFISH_FULL_RESTART_MONITOR=true
SYNC_BETTAFISH_FULL_INCLUDE_TRAINING_DATA=true
SYNC_BETTAFISH_FULL_INCLUDE_RUNTIME_STATE=false
SYNC_BETTAFISH_FULL_SEMANTIC_MODELS=svm,bayes,xgboost
SYNC_BETTAFISH_FULL_SEMANTIC_DEP_PACKAGES=numpy==1.26.4 scipy==1.11.4 scikit-learn==1.2.2 xgboost==2.0.3

# MindSpider Douyin bridge for the main monitor. It reads JSON/CSV/JSONL experimental exports and,
# when DB_* or MINDSPIDER_DB_* are configured, directly queries the douyin_aweme table.
MINDSPIDER_DOUYIN_ENABLED=true
# Multiple paths are allowed, separated by ; on Windows or : on Linux.
MINDSPIDER_DOUYIN_IMPORT_DIR=data/mindspider-douyin-imports
MINDSPIDER_ENV_FILE=
# Supported dialects: mysql, postgresql, sqlite. SQLite is useful for user-space research deployments.
MINDSPIDER_DB_DIALECT=mysql
MINDSPIDER_DB_HOST=
MINDSPIDER_DB_PORT=3306
MINDSPIDER_DB_USER=
MINDSPIDER_DB_PASSWORD=
MINDSPIDER_DB_NAME=mindspider
MINDSPIDER_SQLITE_PATH=
MINDSPIDER_SQLITE_COMMAND=sqlite3
MINDSPIDER_DOUYIN_TABLE=douyin_aweme
MINDSPIDER_DOUYIN_COMMENTS_TABLE=douyin_aweme_comment
MINDSPIDER_DB_LIMIT=1000

# Optional authorized API source secrets. Keep real values out of Git.
DOUYIN_OPEN_PLATFORM_COMMENTS_URL=
DOUYIN_OPEN_PLATFORM_ACCESS_TOKEN=
JULIANG_SUANSHU_ENDPOINT=
JULIANG_SUANSHU_TOKEN=
DOUYIN_VENDOR_ENDPOINT=
DOUYIN_VENDOR_TOKEN=

# DingTalk robot notification. Keep real webhook/secret on the server only.
# State files deduplicate pushed items across restarts.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_STATE_PATH=/opt/ss-monitor/state/dingtalk-ss1-state.json
DINGTALK_SS2_WEBHOOK=
DINGTALK_SS2_SECRET=
DINGTALK_SS2_STATE_PATH=/opt/ss-monitor/state/dingtalk-ss2-state.json
# Generic robots for custom project ids. Prefer webhookEnv/secretEnv so the JSON
# shape can stay reusable while real values remain separate local env entries.
# DINGTALK_ROBOTS_JSON=[{"gameId":"out-of-control","shortName":"失控进化","webhookEnv":"DINGTALK_OUT_OF_CONTROL_WEBHOOK","secretEnv":"DINGTALK_OUT_OF_CONTROL_SECRET","statePath":"/opt/ss-monitor/state/dingtalk-out-of-control-state.json"}]
DINGTALK_ROBOTS_JSON=

# 抖音不使用官方接口：当前通过公开搜索结果发现公开视频/图文，并严格按时间窗口过滤。
# 不配置 Cookie；如果公开搜索被安全验证拦截，平台会在采集状态里标注受限。
